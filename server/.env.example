# Gmail SMTP credentials used by Nodemailer.
# EMAIL_PASS must be a Gmail App Password (Google Account -> Security -> 2-Step
# Verification -> App passwords), not your regular account password.
EMAIL_USER=anakniusahay@gmail.com
EMAIL_PASS=tgoftvgckinewwxb

# Optional: mailbox that receives contact form submissions. Defaults to EMAIL_USER.
CONTACT_RECEIVER_EMAIL=anakniusahay@gmail.com

# Port the server listens on. Render sets this automatically in production.
PORT=5000

# Comma-separated list of origins allowed to call this API (your Netlify site
# URL, plus http://localhost:5173 for local frontend development).
CLIENT_ORIGIN=http://localhost:5173,https://your-site.netlify.app
